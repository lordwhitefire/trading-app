            {activeTab === 'results' && (
                <div className="space-y-3">
                    {savedResults.length === 0 ? (
                        <div className="border border-dashed border-[#1F1F1F] rounded-xl p-12 text-center">
                            <p className="text-[#4B5563] text-sm mb-4">No saved results yet.</p>
