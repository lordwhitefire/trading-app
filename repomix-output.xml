          <p className="text-[10px] font-semibold uppercase tracking-widest text-[#4B5563] mb-3">
            {card.label}
          </p>
          <p className={`text-2xl font-mono font-bold ${card.color}`}>
            {card.format(card.value)}
          </p>
        </div>
      ))}
    </div>
  );
}
