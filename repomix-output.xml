    return (
        <div className="max-w-[1280px] mx-auto px-4 py-8 pb-32 space-y-8">

            {/* Profile header */}
            <div className="bg-[#0D0D0D] border border-[#1F1F1F] rounded-xl p-6">
                <div className="flex items-center gap-5">
                    <img
