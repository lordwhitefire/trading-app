        className="mt-4 w-full flex items-center justify-center gap-2 bg-[#FACC15] hover:bg-[#FDD047] text-black font-bold text-xs uppercase tracking-widest py-2.5 rounded-lg transition-colors"
      >
        Place Trade →
      </button>
